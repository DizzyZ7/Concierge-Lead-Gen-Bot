# Telegram Bot (admin panel)
BOT_TOKEN=

# Telegram User Account (parser + optional direct posting)
TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_SESSION_NAME=concierge_session

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# Human reviewers who receive approved comments in private messages.
# If empty, comments are sent to ADMIN_IDS. Reviewers must open /start in the bot first.
REVIEWER_CHAT_IDS=123456789

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/concierge

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Settings
TIMEZONE=Asia/Bangkok
AUTO_APPROVE=false
MAX_DAILY_COMMENTS=30
WARMUP_MODE=true
ACCOUNT_STARTED_AT=
MIN_COMMENT_HOUR=9
MAX_COMMENT_HOUR=22
PARSER_LIMIT_PER_CHANNEL=20

# Recommended start mode:
# REVIEWER_MODE=true means approved comments are sent to a human in DM first.
# POSTING_ENABLED=false keeps direct channel posting disabled.
REVIEWER_MODE=true
POSTING_ENABLED=false
